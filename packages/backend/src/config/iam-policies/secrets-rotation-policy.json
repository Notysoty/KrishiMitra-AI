{
  "_comment": "IAM policy for the AWS Secrets Manager rotation Lambda. Grants permissions to rotate DB passwords and API keys. Used by the automatic rotation Lambda function.",
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "RotateSecrets",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:DescribeSecret",
        "secretsmanager:GetSecretValue",
        "secretsmanager:PutSecretValue",
        "secretsmanager:UpdateSecretVersionStage"
      ],
      "Resource": [
        "arn:aws:secretsmanager:*:*:secret:krishimitra/*"
      ]
    },
    {
      "Sid": "RDSPasswordRotation",
      "Effect": "Allow",
      "Action": [
        "rds-db:connect"
      ],
      "Resource": [
        "arn:aws:rds-db:*:*:dbuser:*/krishimitra_*"
      ]
    },
    {
      "Sid": "LambdaVPCAccess",
      "Effect": "Allow",
      "Action": [
        "ec2:CreateNetworkInterface",
        "ec2:DeleteNetworkInterface",
        "ec2:DescribeNetworkInterfaces"
      ],
      "Resource": "*"
    }
  ]
}
